# ── Database ─────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/finace
DB_USER=finace
DB_PASSWORD=finace_dev_password

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=replace_me_with_a_64_byte_random_base64_string_replace_me_with_a_64_byte
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# ── CORS (comma-separated) ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── Mail (Gmail SMTP with app password) ──────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_FROM=Antigone <your@gmail.com>

# ── Google OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── File storage ─────────────────────────────────────────────────────────────
STORAGE_PATH=./storage

# ── App ──────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:5173
